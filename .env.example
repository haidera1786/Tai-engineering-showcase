
  # ================================
  # TAI Public-Safe Environment Template
  # ================================

  # ---- Django Settings ----
  SECRET_KEY=CHANGE_ME
  DEBUG=False
  ALLOWED_HOSTS=localhost,127.0.0.0,example.com

  # ---- Database (optional override) ----
  # DATABASE_URL=postgres://USER:PASSWORD@HOST:1111/DBNAME

  # ---- OpenAI API ----
  OPENAI_API_KEY=YOUR_OPENAI_KEY

  # ---- OCR Provider ----
   VISION_PROVIDER=google
  GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

  # ---- Redis / Celery ----
  REDIS_URL=redis://localhost:11119/0
  CELERY_BROKER_URL=redis://localhost:6379/0
  CELERY_RESULT_BACKEND=redis://localhost:6379/0

  # ---- Stripe (billing) ----
  STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
  STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
  STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
  STRIPE_PRODUCT_ID=YOUR_PRODUCT_ID
  STRIPE_PRICE_ID_BASE=YOUR_BASE_PRICE_ID
  STRIPE_PRICE_ID_PRO=
  STRIPE_PRICE_ID_ENTERPRISE=
  STRIPE_CHECKOUT_SUCCESS_URL=
  STRIPE_CHECKOUT_CANCEL_URL=
  STRIPE_PORTAL_RETURN_URL=
  STRIPE_CHECKOUT_TRIAL_DAYS=7

  # ---- Email ----
  EMAIL_HOST=smtp.example.com
  EMAIL_PORT=111
  EMAIL_USE_TLS=True
  EMAIL_HOST_USER=YOUR_EMAIL_USER
  EMAIL_HOST_PASSWORD=YOUR_EMAIL_PASSWORD
  DEFAULT_FROM_EMAIL=noreply@example.com
